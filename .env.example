# ============================================
# Frontend Environment Variables (Public)
# ============================================
NEXT_PUBLIC_APP_URL=https://thestudysync.vercel.app

# Firebase Client Configuration (Get from Firebase Console > Project Settings)
NEXT_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_app_id

# ============================================
# Backend Environment Variables (Server-side)
# ============================================

# MongoDB Connection String
# Get from MongoDB Atlas > Database > Connect > Drivers
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/database_name?retryWrites=true&w=majority

# Optional: DNS servers used for the Atlas SRV lookup (mongodb+srv://).
# Set this if you hit "querySrv ECONNREFUSED" — forces a public resolver.
# Comma-separated; defaults to 8.8.8.8,1.1.1.1 when MONGODB_URI is an SRV URI.
# MONGODB_DNS_SERVERS=8.8.8.8,1.1.1.1

# Optional: Non-SRV fallback connection string, used automatically if the SRV
# DNS lookup is refused. Get it from Atlas > Connect > "I don't have SRV"
# (looks like: mongodb://host1:27017,host2:27017,host3:27017/db?ssl=true&replicaSet=...&authSource=admin)
# MONGODB_URI_FALLBACK=

# Firebase Admin SDK Service Account Key (Base64 Encoded)
# 1. Download serviceAccountKey.json from Firebase Console > Project Settings > Service Accounts
# 2. Encode it to base64:
#    Windows: [Convert]::ToBase64String([System.IO.File]::ReadAllBytes("serviceAccountKey.json"))
#    Linux/Mac: base64 -w 0 serviceAccountKey.json
FIREBASE_SERVICE_ACCOUNT_KEY=your_base64_encoded_service_account_key

# YouTube Data API v3 Key
# Get from: https://console.cloud.google.com/apis/credentials
# Enable YouTube Data API v3 first
YOUTUBE_API_KEY=your_youtube_api_key

# Gmail SMTP Configuration
GMAIL_USER=your-email@gmail.com
GMAIL_APP_PASSWORD=your-16-char-app-password

# ImgBB API Key for Image Uploads
# Get from: https://api.imgbb.com/
NEXT_PUBLIC_IMGBB_API_KEY=your_imgbb_api_key
